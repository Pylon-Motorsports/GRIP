{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/Pylon-Motorsports/GRIP/main/car-status-batch.schema.json",
    "title": "GripCarStatusBatch",
    "description": "A batch of car-status samples for a single car, typically used for delayed / aggregated upload (offline backlog, periodic flush). All samples share the same `car` declared once at the batch level. Each entry in `samples` carries the same fields as a single car-status document minus the `car` block. Validate samples one-by-one against car-status.schema.json by promoting their `car` field from the batch root.",
    "type": "object",
    "additionalProperties": false,
    "required": ["schemaVersion", "car", "samples"],
    "definitions": {
        "extensions": {
            "type": "object",
            "description": "App-specific namespaced data. Keys are app slugs (kebab-case recommended).",
            "additionalProperties": { "type": "object" }
        },
        "sample": {
            "type": "object",
            "additionalProperties": false,
            "required": ["position"],
            "properties": {
                "clientCapturedAt": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "ISO 8601 UTC instant the sample was captured on the in-car device. Set by the producer."
                },
                "serverReceivedAt": {
                    "type": ["string", "null"],
                    "format": "date-time",
                    "description": "ISO 8601 UTC instant the sample was received by the ingest server."
                },
                "position": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["lat", "lon"],
                    "properties": {
                        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
                        "altMeters": { "type": ["number", "null"] },
                        "accuracyMeters": { "type": ["number", "null"], "minimum": 0 },
                        "source": {
                            "type": "string",
                            "enum": ["gps", "dr", "hybrid"]
                        }
                    }
                },
                "speedMetersPerSecond": { "type": ["number", "null"], "minimum": 0 },
                "headingDegrees": {
                    "type": ["number", "null"],
                    "minimum": 0,
                    "exclusiveMaximum": 360
                },
                "emergency": { "type": "boolean" },
                "extensions": { "$ref": "#/definitions/extensions" }
            }
        }
    },
    "properties": {
        "schemaVersion": {
            "type": "integer",
            "description": "Version of the car-status-batch schema this document conforms to.",
            "const": 1
        },
        "car": {
            "type": "object",
            "additionalProperties": false,
            "required": ["number"],
            "properties": {
                "number": { "type": "string" },
                "id": { "type": "string", "format": "uuid" }
            }
        },
        "samples": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/sample" }
        },
        "extensions": { "$ref": "#/definitions/extensions" }
    }
}
